<article class="ui-card h-full">
    {% if badge is defined and badge is not empty %}
        <p class="mb-2 inline-flex w-fit rounded-full border border-indigo-400/40 bg-indigo-500/10 px-2.5 py-1 text-xs font-medium text-indigo-200">
            {{ badge }}
        </p>
    {% endif %}

    <h2 class="text-lg font-semibold">{{ title|default('Carte') }}</h2>
    <p class="mt-2 text-sm text-slate-300">{{ content|default('') }}</p>
</article>
